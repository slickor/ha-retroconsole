# HA RetroConsole Release Automation Script - FIXED

# 1. Version aus ha_client.py extrahieren
$clientFile = "tools/ha_client.py"
if (-not (Test-Path $clientFile)) { Write-Error "ha_client.py nicht gefunden!"; exit }
$version = (Select-String -Path $clientFile -Pattern 'VERSION = "(.*)"').Matches.Groups[1].Value

Write-Host "Starte Release-Prozess für Version $version..." -ForegroundColor Cyan

# 2. Änderungen aus CHANGELOG.md extrahieren
$changelogFile = "CHANGELOG.md"
$changelogContent = Get-Content $changelogFile -Raw
$escapedVersion = [regex]::Escape($version)
$pattern = "(?s)## \[$escapedVersion\] - .*?\r?\n(.*?)(?=\r?\n## \[|$)"
if ($changelogContent -match $pattern) {
    $changes = $Matches[1].Trim()
} else {
    $changes = "Updated to v$version"
}

# 3. Struktur für PortMaster vorbereiten (Staging)
$stagingDir = "build_staging"
$appFolder = "$stagingDir/ha-retroconsole"

if (Test-Path $stagingDir) { Remove-Item -Recurse -Force $stagingDir }
New-Item -ItemType Directory -Path $appFolder | Out-Null

Write-Host "Bereite PortMaster-Struktur vor..." -ForegroundColor Yellow

# A. Den App-Inhalt kopieren (Vollständige Liste inkl. install.sh und LICENSE)
$itemList = @(
    "tools", "ui", "assets", "libs", "docs", "README.md", "CHANGELOG.md", 
    "config.example.json", "requirements.txt", "port.json", "gameinfo.xml", 
    "cover.png", "screenshot.png", "LICENSE", "install.sh"
)
foreach ($item in $itemList) {
    if (Test-Path $item) {
        Copy-Item -Path $item -Destination $appFolder -Recurse -Force
    }
}

# B. Launcher kopieren und Zeilenumbrüche für Linux korrigieren (LF)
$launcherName = "Home Assistant - for retroconsoles.sh"
if (Test-Path "ha-retroconsole.sh") {
    $shContent = Get-Content "ha-retroconsole.sh" -Raw
    $shContent = $shContent -replace "`r`n", "`n"
    [IO.File]::WriteAllText("$PSScriptRoot/$stagingDir/$launcherName", $shContent, (New-Object System.Text.UTF8Encoding($false)))
}

# C. install.sh ebenfalls auf LF korrigieren (Sehr wichtig!)
if (Test-Path "$appFolder/install.sh") {
    $instContent = Get-Content "$appFolder/install.sh" -Raw
    $instContent = $instContent -replace "`r`n", "`n"
    [IO.File]::WriteAllText("$PSScriptRoot/$appFolder/install.sh", $instContent, (New-Object System.Text.UTF8Encoding($false)))
}

# D. Menü-Bild auf Root-Ebene
if (Test-Path "cover.png") {
    Copy-Item -Path "cover.png" -Destination "$stagingDir/Home Assistant - for retroconsoles.png" -Force
}

# 4. ZIP erstellen
$releaseDir = "release"
if (-not (Test-Path $releaseDir)) { New-Item -ItemType Directory -Path $releaseDir | Out-Null }
$zipName = "$releaseDir/ha-retroconsole-v$version.zip"

Compress-Archive -Path "$stagingDir/*" -DestinationPath $zipName -Force

# 5. Aufräumen
Remove-Item -Recurse -Force $stagingDir

# 6. Git Commit und Tagging
Write-Host "Führe Git-Commit aus..." -ForegroundColor Cyan
git add .
git commit -m "Release v$version`n`n$changes"
git tag -a "v$version" -m "Release v$version"

Write-Host "Fertig! Das ZIP unter $zipName ist nun vollständig und Linux-kompatibel." -ForegroundColor Green
